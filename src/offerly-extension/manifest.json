{
  "manifest_version": 3,
  "name": "Offerly",
  "version": "1.0",
  "description": "Save job applications to Offerly.",
  "permissions": ["activeTab", "tabs", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Offerly",
    "default_icon": {
      "16": "offerly.png",
      "48": "offerly.png",
      "128": "offerly.png"
    }
  },
  "icons": {
    "16": "offerly.png",
    "48": "offerly.png",
    "128": "offerly.png"
  }
}